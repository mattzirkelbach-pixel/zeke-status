  html+='<div class="kv"><span class="k">LaunchAgents</span><span class="val">20 active</span></div>';
  html+='<div class="kv"><span class="k">Cron jobs</span><span class="val">6</span></div>';
  document.getElementById('infra-card').innerHTML=html;
}

